    <disable_collisions link1="chassis_link" link2="post_0_link" reason="Never"/>
    <disable_collisions link1="chassis_link" link2="rear_left_wheel_link" reason="Never"/>
    <disable_collisions link1="chassis_link" link2="rear_right_wheel_link" reason="Never"/>
    <disable_collisions link1="chassis_link" link2="right_diff_unit_link" reason="Adjacent"/>
    <disable_collisions link1="chassis_link" link2="structure_link" reason="Adjacent"/>
    <disable_collisions link1="chassis_link" link2="tower_link" reason="Never"/>
    <disable_collisions link1="disk_0_link" link2="front_left_wheel_link" reason="Never"/>
    <disable_collisions link1="disk_0_link" link2="front_right_wheel_link" reason="Never"/>
