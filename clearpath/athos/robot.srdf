    <disable_collisions link1="front_left_wheel_link" link2="structure_link" reason="Never"/>
    <disable_collisions link1="front_left_wheel_link" link2="tower_link" reason="Never"/>
    <disable_collisions link1="front_right_wheel_link" link2="left_diff_unit_link" reason="Never"/>
    <disable_collisions link1="front_right_wheel_link" link2="lidar3d_0_link" reason="Never"/>
    <disable_collisions link1="front_right_wheel_link" link2="post_0_link" reason="Never"/>
