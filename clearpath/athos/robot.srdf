    <disable_collisions link1="disk_0_link" link2="right_diff_unit_link" reason="Never"/>
    <disable_collisions link1="disk_0_link" link2="structure_link" reason="Never"/>
    <disable_collisions link1="disk_0_link" link2="tower_link" reason="Never"/>
