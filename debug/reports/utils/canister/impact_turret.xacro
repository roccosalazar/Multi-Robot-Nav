<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="impact_turret">

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(mass / 12.0) * (y * y + z * z)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(mass / 12.0) * (x * x + z * z)}"
        iyz="0.0"
        izz="${(mass / 12.0) * (x * x + y * y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(mass / 12.0) * (3.0 * radius * radius + length * length)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(mass / 12.0) * (3.0 * radius * radius + length * length)}"
        iyz="0.0"
        izz="${0.5 * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <material name="impact_olive">
    <color rgba="0.56 0.60 0.46 1.0"/>
  </material>

  <material name="impact_dark_olive">
    <color rgba="0.42 0.46 0.35 1.0"/>
  </material>

  <material name="impact_shadow_olive">
    <color rgba="0.32 0.36 0.28 1.0"/>
  </material>

  <material name="impact_dark">
    <color rgba="0.14 0.15 0.16 1.0"/>
  </material>

  <material name="impact_black">
    <color rgba="0.07 0.07 0.08 1.0"/>
  </material>

  <material name="impact_sensor_glass">
    <color rgba="0.20 0.24 0.34 0.90"/>
  </material>

  <xacro:macro name="impact_turret" params="
      parent:=base_link
      prefix:=impact_
      xyz:='0 0 0'
      rpy:='0 0 0'
      yaw_limit:='3.14159'
      pitch_min:='-0.35'
      pitch_max:='0.95'">

    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0.0225" rpy="0 0 0"/>
        <geometry>
          <box size="0.44 0.44 0.045"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="0 0 0.040" rpy="0 0 0"/>
        <geometry>
          <box size="0.31 0.31 0.020"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0.0225" rpy="0 0 0"/>
        <geometry>
          <box size="0.44 0.44 0.045"/>
        </geometry>
      </collision>

      <xacro:box_inertia mass="14.0" x="0.44" y="0.44" z="0.045"/>
    </link>

    <joint name="${prefix}base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <link name="${prefix}pedestal_link">
      <visual>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.165" length="0.050"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="0 0 0.155" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.135" length="0.260"/>
        </geometry>
        <material name="impact_olive"/>
      </visual>

      <visual>
        <origin xyz="0 0 0.290" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.155" length="0.030"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0.155" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.145" length="0.310"/>
        </geometry>
      </collision>

      <xacro:cylinder_inertia mass="26.0" radius="0.145" length="0.310"/>
    </link>

    <joint name="${prefix}pedestal_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}pedestal_link"/>
      <origin xyz="0 0 0.045" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}yaw_link">
      <visual>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.175" length="0.050"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="0 0 0.085" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.155" length="0.070"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="0.00 0.00 0.165" rpy="0 0 0"/>
        <geometry>
          <box size="0.44 0.38 0.11"/>
        </geometry>
        <material name="impact_olive"/>
      </visual>

      <visual>
        <origin xyz="0.12 0.00 0.165" rpy="0 0 0"/>
        <geometry>
          <box size="0.14 0.30 0.13"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0.105" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.175" length="0.210"/>
        </geometry>
      </collision>

      <xacro:cylinder_inertia mass="34.0" radius="0.175" length="0.210"/>
    </link>

    <joint name="${prefix}yaw_joint" type="revolute">
      <parent link="${prefix}pedestal_link"/>
      <child link="${prefix}yaw_link"/>
      <origin xyz="0 0 0.310" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-yaw_limit}" upper="${yaw_limit}" effort="500.0" velocity="1.0"/>
      <dynamics damping="8.0" friction="2.0"/>
    </joint>

    <link name="${prefix}pitch_link">
      <visual>
        <origin xyz="0.05 0 0.03" rpy="0 0 0"/>
        <geometry>
          <box size="0.46 0.34 0.26"/>
        </geometry>
        <material name="impact_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.16 0 0.02" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="0.155" length="0.30"/>
        </geometry>
        <material name="impact_olive"/>
      </visual>

      <visual>
        <origin xyz="0.02 0 0.185" rpy="0 0.28 0"/>
        <geometry>
          <box size="0.34 0.29 0.07"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.06 0.165 0.03" rpy="0 0 0"/>
        <geometry>
          <box size="0.18 0.05 0.19"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.06 -0.165 0.03" rpy="0 0 0"/>
        <geometry>
          <box size="0.18 0.05 0.19"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="0.10 0 -0.08" rpy="0 0 0"/>
        <geometry>
          <box size="0.42 0.24 0.08"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.17 0.12 0.00" rpy="0 0 0"/>
        <geometry>
          <box size="0.07 0.07 0.18"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.17 -0.12 0.00" rpy="0 0 0"/>
        <geometry>
          <box size="0.07 0.07 0.18"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <collision>
        <origin xyz="0.00 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.54 0.36 0.32"/>
        </geometry>
      </collision>

      <xacro:box_inertia mass="48.0" x="0.54" y="0.36" z="0.32"/>
    </link>

    <joint name="${prefix}pitch_joint" type="revolute">
      <parent link="${prefix}yaw_link"/>
      <child link="${prefix}pitch_link"/>
      <origin xyz="0.00 0 0.205" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${pitch_min}" upper="${pitch_max}" effort="450.0" velocity="0.8"/>
      <dynamics damping="10.0" friction="2.5"/>
    </joint>

    <link name="${prefix}launcher_left_upper_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 -0.43 0"/>
        <geometry>
          <box size="0.48 0.21 0.15"/>
        </geometry>
        <material name="impact_olive"/>
      </visual>

      <visual>
        <origin xyz="0.18 0 0" rpy="0 -0.43 0"/>
        <geometry>
          <box size="0.05 0.22 0.16"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.19 0 0" rpy="0 -0.43 0"/>
        <geometry>
          <box size="0.04 0.20 0.13"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.02 0 0.085" rpy="0 -0.43 0"/>
        <geometry>
          <box size="0.34 0.18 0.025"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.02 0 -0.085" rpy="0 -0.43 0"/>
        <geometry>
          <box size="0.34 0.18 0.020"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.24 0 -0.01" rpy="0 0 0"/>
        <geometry>
          <box size="0.07 0.12 0.10"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 -0.43 0"/>
        <geometry>
          <box size="0.48 0.21 0.15"/>
        </geometry>
      </collision>

      <xacro:box_inertia mass="19.0" x="0.48" y="0.21" z="0.15"/>
    </link>

    <joint name="${prefix}launcher_left_upper_joint" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}launcher_left_upper_link"/>
      <origin xyz="-0.12 0.265 0.17" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}launcher_left_lower_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 -0.34 0"/>
        <geometry>
          <box size="0.42 0.19 0.13"/>
        </geometry>
        <material name="impact_olive"/>
      </visual>

      <visual>
        <origin xyz="0.16 0 0" rpy="0 -0.34 0"/>
        <geometry>
          <box size="0.05 0.20 0.14"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.16 0 0" rpy="0 -0.34 0"/>
        <geometry>
          <box size="0.04 0.18 0.11"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.02 0 0.073" rpy="0 -0.34 0"/>
        <geometry>
          <box size="0.28 0.16 0.022"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.22 0 -0.01" rpy="0 0 0"/>
        <geometry>
          <box size="0.07 0.11 0.09"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 -0.34 0"/>
        <geometry>
          <box size="0.42 0.19 0.13"/>
        </geometry>
      </collision>

      <xacro:box_inertia mass="17.0" x="0.42" y="0.19" z="0.13"/>
    </link>

    <joint name="${prefix}launcher_left_lower_joint" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}launcher_left_lower_link"/>
      <origin xyz="-0.17 0.225 -0.03" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}sensor_head_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.33 0.19 0.19"/>
        </geometry>
        <material name="impact_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.08 0 0.06" rpy="0 0.18 0"/>
        <geometry>
          <box size="0.16 0.18 0.07"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.145 0 0.00" rpy="0 0 0"/>
        <geometry>
          <box size="0.025 0.15 0.14"/>
        </geometry>
        <material name="impact_sensor_glass"/>
      </visual>

      <visual>
        <origin xyz="-0.167 0.042 0.045" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.017" length="0.012"/>
        </geometry>
        <material name="impact_sensor_glass"/>
      </visual>

      <visual>
        <origin xyz="-0.167 0.042 -0.003" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.012" length="0.012"/>
        </geometry>
        <material name="impact_sensor_glass"/>
      </visual>

      <visual>
        <origin xyz="-0.167 0.042 -0.052" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.014" length="0.012"/>
        </geometry>
        <material name="impact_sensor_glass"/>
      </visual>

      <visual>
        <origin xyz="0.11 0 -0.10" rpy="0 0 0"/>
        <geometry>
          <box size="0.12 0.13 0.04"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.33 0.19 0.19"/>
        </geometry>
      </collision>

      <xacro:box_inertia mass="14.0" x="0.33" y="0.19" z="0.19"/>
    </link>

    <joint name="${prefix}sensor_head_joint" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}sensor_head_link"/>
      <origin xyz="0.17 -0.225 0.10" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}aux_box_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.34 0.13 0.10"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <visual>
        <origin xyz="0.08 0 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.11 0.11 0.025"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.34 0.13 0.10"/>
        </geometry>
      </collision>

      <xacro:box_inertia mass="10.0" x="0.34" y="0.13" z="0.10"/>
    </link>

    <joint name="${prefix}aux_box_joint" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}aux_box_link"/>
      <origin xyz="0.22 -0.235 -0.07" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}front_support_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.22 0.10 0.07"/>
        </geometry>
        <material name="impact_shadow_olive"/>
      </visual>

      <visual>
        <origin xyz="-0.09 0 0.03" rpy="0 0.20 0"/>
        <geometry>
          <box size="0.08 0.08 0.05"/>
        </geometry>
        <material name="impact_dark_olive"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.22 0.10 0.07"/>
        </geometry>
      </collision>

      <xacro:box_inertia mass="8.0" x="0.22" y="0.10" z="0.07"/>
    </link>

    <joint name="${prefix}front_support_joint" type="fixed">
      <parent link="${prefix}pitch_link"/>
      <child link="${prefix}front_support_link"/>
      <origin xyz="0.26 0 -0.09" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}optical_frame"/>

    <joint name="${prefix}optical_frame_joint" type="fixed">
      <parent link="${prefix}sensor_head_link"/>
      <child link="${prefix}optical_frame"/>
      <origin xyz="-0.18 0.042 0.0" rpy="-1.57079632679 0 -1.57079632679"/>
    </joint>

  </xacro:macro>

</robot>