<?xml version="1.0" encoding="UTF-8"?>
<robot name="camera_turret">
  <link name="world"/>
  
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.06" radius="0.12"/>
      </geometry>
      <material name="base_silver">
        <color rgba="0.75 0.75 0.75 1"/>
      </material>
      <origin rpy="0 0 0" xyz="0 0 0.03"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.06" radius="0.12"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.03"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin rpy="0 0 0" xyz="0 0 0.03"/>
      <inertia ixx="0.0027" iyy="0.0027" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  
  <joint name="fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>
  
  <link name="mobile_link">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
    <box size="0.05 0.08 0.02"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
    <box size="0.05 0.08 0.02"/>
      </geometry>
      <material name="mobile_body_blue">
        <color rgba="0.18 0.40 0.82 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.3" />
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1.7e-4" ixy="0" ixz="0" iyy="7.25e-5" iyz="0" izz="2.225e-4" />
    </inertial>
    
    <!--Left ear-->
    <collision>
      <origin xyz="0 -0.03 0.0695" rpy="0 0 0"/>
      <geometry>
    <box size="0.04 0.02 0.119"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 -0.03 0.0695" rpy="0 0 0"/>
      <geometry>
    <box size="0.04 0.02 0.119"/>
      </geometry>
      <material name="left_ear_green">
        <color rgba="0.20 0.72 0.36 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.3" />
      <origin xyz="0 -0.03 0.0695" rpy="0 0 0"/>
      <inertia ixx="3.640e-4" ixy="0" ixz="0" iyy="3.940e-4" iyz="0" izz="5e-5" />
    </inertial>
    
    <!--Right ear-->
    <collision>
      <origin xyz="0 0.03 0.0695" rpy="0 0 0"/>
      <geometry>
    <box size="0.04 0.02 0.119"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0.03 0.0695" rpy="0 0 0"/>
      <geometry>
    <box size="0.04 0.02 0.119"/>
      </geometry>
      <material name="right_ear_orange">
        <color rgba="0.95 0.55 0.18 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.3" />
      <origin xyz="0 0.03 0.0695" rpy="0 0 0"/>
      <inertia ixx="3.640e-4" ixy="0" ixz="0" iyy="3.940e-4" iyz="0" izz="5e-5" />
    </inertial>    
  </link>  
  <joint name="mobileBase_joint" type="continuous">
    <axis xyz="0 0 1" />
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="mobile_link"/>
  </joint>  

  <link name="camera_link">
    <collision>
      <origin xyz="0.084 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
    <cylinder length="0.56" radius="0.02"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0.084 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
    <cylinder length="0.56" radius="0.02"/>
      </geometry>
      <material name="camera_yellow">
        <color rgba="0.95 0.86 0.20 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.2" />
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="4e-5" ixy="0" ixz="0" iyy="8e-5" iyz="0" izz="8e-5" />
    </inertial>
  </link>
  <joint name="camera_joint" type="continuous">
    <axis xyz="0 1 0" />
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
    <parent link="mobile_link"/>
    <child link="camera_link"/>
  </joint>  
  
</robot>