<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dual_canister_test">

  <material name="mat_base">
    <color rgba="0.29 0.29 0.30 1.0"/>
  </material>

  <material name="mat_canister_body">
    <color rgba="0.24 0.24 0.25 1.0"/>
  </material>

  <material name="mat_canister_cap">
    <color rgba="0.12 0.12 0.13 1.0"/>
  </material>

  <material name="mat_tower_stem">
    <color rgba="0.10 0.10 0.10 1.0"/>
  </material>

  <material name="mat_dark_detail">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>

  <material name="mat_mid_detail">
    <color rgba="0.18 0.18 0.19 1.0"/>
  </material>

  <material name="mat_soft_panel">
    <color rgba="0.34 0.34 0.35 1.0"/>
  </material>

  <link name="base_plate">
    <inertial>
      <origin xyz="-0.006 0 0.0005" rpy="0 0 0"/>
      <mass value="14.0"/>
      <inertia ixx="0.430" ixy="0.0" ixz="0.0" iyy="0.760" iyz="0.0" izz="1.160"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.80 0.60 0.025"/>
      </geometry>
      <material name="mat_base"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.016" rpy="0 0 0"/>
      <geometry>
        <box size="0.72 0.42 0.010"/>
      </geometry>
      <material name="mat_soft_panel"/>
    </visual>

    <visual>
      <origin xyz="-0.02 0.24 -0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.05 0.030"/>
      </geometry>
      <material name="mat_dark_detail"/>
    </visual>

    <visual>
      <origin xyz="-0.02 -0.24 -0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.05 0.030"/>
      </geometry>
      <material name="mat_dark_detail"/>
    </visual>

    <visual>
      <origin xyz="0.24 0 0.0175" rpy="0 0 0"/>
      <geometry>
        <box size="0.14 0.50 0.006"/>
      </geometry>
      <material name="mat_mid_detail"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.80 0.60 0.025"/>
      </geometry>
    </collision>

    <collision>
      <origin xyz="-0.02 0.24 -0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.05 0.030"/>
      </geometry>
    </collision>

    <collision>
      <origin xyz="-0.02 -0.24 -0.020" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.05 0.030"/>
      </geometry>
    </collision>

    <collision>
      <origin xyz="0.24 0 0.0175" rpy="0 0 0"/>
      <geometry>
        <box size="0.14 0.50 0.006"/>
      </geometry>
    </collision>
  </link>

  <joint name="payload_mount_joint" type="fixed">
    <parent link="default_mount"/>
    <child link="base_plate"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="base_plate_joint" type="fixed">
    <parent link="base_plate"/>
    <child link="payload_base_link"/>
    <origin xyz="-0.30 0 0.0625" rpy="0 0 0"/>
  </joint>

  <link name="lidar_tower">
    <inertial>
      <origin xyz="0 0 0.248" rpy="0 0 0"/>
      <mass value="4.2"/>
      <inertia ixx="0.089" ixy="0.0" ixz="0.0" iyy="0.089" iyz="0.0" izz="0.0048"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.06"/>
      </geometry>
      <material name="mat_canister_cap"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <material name="mat_mid_detail"/>
