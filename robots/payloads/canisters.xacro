      <geometry>
        <box size="0.10 0.06 0.05"/>
      </geometry>
      <material name="mat_dark_detail"/>
    </visual>

    <visual>
      <origin xyz="0.035 -0.19 0.105" rpy="0 0.45 0"/>
      <geometry>
        <box size="0.10 0.06 0.05"/>
      </geometry>
      <material name="mat_dark_detail"/>
    </visual>

    <visual>
      <origin xyz="-0.045 0.19 0.102" rpy="0 -0.35 0"/>
      <geometry>
        <box size="0.09 0.06 0.045"/>
      </geometry>
      <material name="mat_mid_detail"/>
    </visual>

    <visual>
      <origin xyz="-0.045 -0.19 0.102" rpy="0 -0.35 0"/>
      <geometry>
        <box size="0.09 0.06 0.045"/>
      </geometry>
      <material name="mat_mid_detail"/>
    </visual>

    <visual>
      <origin xyz="0.07 0 0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.40 0.02"/>
      </geometry>
      <material name="mat_canister_cap"/>
    </visual>

    <visual>
      <origin xyz="-0.085 0 0.070" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.36 0.05"/>
      </geometry>
