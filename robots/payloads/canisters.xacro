      <geometry>
        <cylinder length="0.10" radius="0.10"/>
      </geometry>
    </collision>
  </link>

  <link name="right_canister_link">
    <inertial>
      <origin xyz="0.325 0 0.10" rpy="0 0 0"/>
      <mass value="21.0"/>
      <inertia ixx="0.067" ixy="0.0" ixz="0.0" iyy="1.90" iyz="0.0" izz="1.90"/>
    </inertial>

    <visual>
      <origin xyz="0.30 0 0.10" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder length="1.00" radius="0.09"/>
