      <geometry>
        <cylinder length="0.01" radius="0.060"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_tower_joint" type="fixed">
    <parent link="base_plate"/>
    <child link="lidar_tower"/>
    <origin xyz="0 0 0.0125" rpy="0 0 0"/>
  </joint>

  <link name="turret_lidar_mount">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="turret_lidar_mount_joint" type="fixed">
    <parent link="lidar_tower"/>
    <child link="turret_lidar_mount"/>
    <origin xyz="0 0 0.565" rpy="0 0 0"/>
  </joint>

  <link name="payload_base_link">
    <inertial>
      <origin xyz="0.005 0 0.066" rpy="0 0 0"/>
      <mass value="26.0"/>
      <inertia ixx="0.640" ixy="0.0" ixz="0.0" iyy="0.150" iyz="0.0" izz="0.690"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.58 0.10"/>
      </geometry>
      <material name="mat_base"/>
    </visual>

    <visual>
      <origin xyz="0 -0.19 0.07" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder length="0.19" radius="0.10"/>
      </geometry>
      <material name="mat_soft_panel"/>
    </visual>

    <visual>
      <origin xyz="0 0.19 0.07" rpy="1.5708 0 0"/>
