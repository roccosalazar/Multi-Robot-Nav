    <visual>
      <origin xyz="0 0 0.56" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.01" radius="0.060"/>
      </geometry>
      <material name="mat_canister_cap"/>
    </visual>

    <collision>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.06"/>
