{
  "name": "Humble Desktop-Full", // Name of the dev container configuration
  "dockerFile": "Dockerfile", // Path to the Dockerfile that defines the container image
  "remoteUser": "ubuntu", // User to use inside the container
  "runArgs": [ // How to run the container
    "--privileged", // Grants extended privileges to the container (necessary for GUI applications)
    "--network=host",
    "--ipc=host",
    "--device=/dev/dri",
    "--group-add=992",
    "--group-add=44",
    "-it"
  ],
  "containerEnv": { // Environment variables to set inside the container
    "DISPLAY": "${localEnv:DISPLAY}", // Pass the host's DISPLAY variable to enable GUI applications
    "QT_X11_NO_MITSHM": "1",
    "ALSOFT_DRIVERS": "null" // Use the null driver for OpenAL to avoid audio issues in the container
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/ubuntu/${localWorkspaceFolderBasename},type=bind",
  "workspaceFolder": "/home/ubuntu/${localWorkspaceFolderBasename}",
  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.bash_history,target=/home/ubuntu/.bash_history,type=bind",
    "source=${localWorkspaceFolder}/clearpath,target=/home/ubuntu/clearpath,type=bind" // Bind mount for the clearpath robot
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-python.python",
        "ranch-hand-robotics.rde-ros-2",
        "ranch-hand-robotics.rde-pack",
        "ranch-hand-robotics.urdf-editor",
        "github.copilot-chat"
        ]
      }
  }
  ,
  "postCreateCommand": "sudo mkdir -p /tmp/runtime-ubuntu && sudo chmod 700 /tmp/runtime-ubuntu && sudo chown ubuntu:ubuntu /tmp/runtime-ubuntu"
}

// WorkspaceMount stands for how the workspace folder on the host machine is mounted inside the container. In this case, it uses a bind mount to link the local workspace folder to a directory inside the container.
// WorkspaceFolder is the path inside the container where the workspace will be located. It uses the basename of the local workspace folder to create a corresponding directory inside the container.
// localWorkspaceFolder: The path to the workspace folder on the host machine
// localWorkspaceFolderBasename: The name of the workspace folder (without the path)
// localEnv:DISPLAY: The DISPLAY environment variable from the host machine, used to enable GUI
// localEnv:HOME: The home directory of the user on the host machine
// localEnv:USERPROFILE: The user profile directory on Windows, used as an alternative to